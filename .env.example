# ═══════════════════════════════════════════════════
# chat_aqvayli — Environment Variables
# ═══════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env (it's in .gitignore).
# ═══════════════════════════════════════════════════

# ─── Google Gemini API (required for OCR, ASR, RAT) ───
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ─── LLM APIs (used in notebooks) ───
OPENAI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ─── HuggingFace (for NLLB model download) ───
# Only needed for gated models. Get token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ─── Azure Blob Storage (for deployment/radio recording) ───
# Connection string from: Azure Portal → Storage Account → Access Keys
AZURE_STORAGE_CONNECTION_STRING=""
CONTAINER_NAME="recordings"

# ─── Other ───
ARX=
